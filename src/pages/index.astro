  .p1 { width: 2px; height: 2px; background: var(--color-accent); top: 10%;  left: 8%;  animation: float-particle 6s ease-in-out 0s    infinite; box-shadow: 0 0 4px var(--color-accent); }
  .p2 { width: 2px; height: 2px; background: var(--color-purple); top: 20%;  right: 6%; animation: float-particle 7s ease-in-out 1.2s  infinite; box-shadow: 0 0 4px var(--color-purple); }
  .p3 { width: 3px; height: 3px; background: var(--color-accent); bottom: 15%; left: 12%; animation: float-particle 8s ease-in-out 0.6s  infinite; box-shadow: 0 0 6px var(--color-accent); }
  .p4 { width: 2px; height: 2px; background: var(--color-purple); bottom: 25%; right: 10%; animation: float-particle 6.5s ease-in-out 2s  infinite; box-shadow: 0 0 4px var(--color-purple); }
  .p5 { width: 2px; height: 2px; background: var(--color-accent); top: 50%;  left: 3%;  animation: float-particle 9s ease-in-out 0.4s  infinite; box-shadow: 0 0 4px var(--color-accent); }
  .p6 { width: 2px; height: 2px; background: var(--color-purple); top: 60%;  right: 4%; animation: float-particle 7.5s ease-in-out 1.8s infinite; box-shadow: 0 0 4px var(--color-purple); }

