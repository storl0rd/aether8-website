---
import Layout from '../layouts/Layout.astro';

const year = new Date().getFullYear();
---

<Layout
  title="Aether8 AI Consulting | AI Consultants in London, Ontario | Agentic AI Solutions"
  description="Aether8 AI Consulting Inc. Forward-deployed agentic AI engineering for small and medium businesses in London, Ontario and across Canada. Custom AI solutions, workflow automation, and SRE-grade reliability."
>

  <!-- ── Navigation ─────────────────────────────────────────────────────────── -->
  <header id="nav" class="fixed top-0 inset-x-0 z-50 transition-all duration-500">
    <div class="max-w-6xl mx-auto px-6">
      <nav class="flex items-center justify-between h-16 border-b border-white/[0.04]">
        <a href="/" class="flex items-center gap-2 cursor-pointer group">
          <span class="text-[13px] font-semibold tracking-[0.25em] uppercase text-white/90">
            AETHER<span class="text-[var(--color-accent)]">8</span><span class="text-white/30">.ai</span>
          </span>
        </a>
        <div class="hidden md:flex items-center gap-1">
          <a href="#services" class="px-4 py-2 text-[11px] text-slate-400 tracking-[0.2em] uppercase hover:text-white transition-colors duration-300 cursor-pointer">Services</a>
          <a href="#products" class="px-4 py-2 text-[11px] text-slate-400 tracking-[0.2em] uppercase hover:text-white transition-colors duration-300 cursor-pointer">Products</a>
          <a href="#about" class="px-4 py-2 text-[11px] text-slate-400 tracking-[0.2em] uppercase hover:text-white transition-colors duration-300 cursor-pointer">About</a>
          <a
            href="mailto:hello@aether8.ai"
            class="ml-4 text-[11px] tracking-[0.15em] uppercase border border-white/10 text-white/80 px-5 py-2 rounded-full hover:border-[var(--color-accent)]/40 hover:text-[var(--color-accent)] hover:bg-[var(--color-accent)]/5 transition-all duration-300 cursor-pointer"
          >Contact</a>
        </div>
        <!-- Mobile hamburger -->
        <button id="mobile-toggle" class="md:hidden flex flex-col gap-[5px] p-2 cursor-pointer" aria-label="Toggle menu">
          <span class="block w-5 h-[1.5px] bg-white/70 transition-all duration-300 origin-center" id="bar1"></span>
          <span class="block w-5 h-[1.5px] bg-white/70 transition-all duration-300" id="bar2"></span>
          <span class="block w-5 h-[1.5px] bg-white/70 transition-all duration-300 origin-center" id="bar3"></span>
        </button>
      </nav>
    </div>
    <!-- Mobile menu panel -->
    <div id="mobile-menu" class="md:hidden overflow-hidden max-h-0 transition-all duration-400 ease-in-out">
      <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-3 border-t border-white/[0.04]">
        <a href="#services" class="mobile-nav-link text-[12px] text-slate-400 tracking-[0.2em] uppercase py-2 hover:text-white transition-colors duration-300">Services</a>
        <a href="#products" class="mobile-nav-link text-[12px] text-slate-400 tracking-[0.2em] uppercase py-2 hover:text-white transition-colors duration-300">Products</a>
        <a href="#about" class="mobile-nav-link text-[12px] text-slate-400 tracking-[0.2em] uppercase py-2 hover:text-white transition-colors duration-300">About</a>
        <a href="mailto:hello@aether8.ai" class="mobile-nav-link text-[12px] text-[var(--color-accent)] tracking-[0.15em] uppercase py-2 transition-colors duration-300">Contact</a>
      </div>
    </div>
  </header>

  <!-- ── Hero ───────────────────────────────────────────────────────────────── -->
  <section class="min-h-screen flex flex-col items-center justify-center text-center px-6 pt-16 relative overflow-hidden">

    <!-- Refined ambient lighting -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/3 left-1/3 w-[800px] h-[500px] bg-[var(--color-accent)]/[0.03] rounded-full blur-[160px]"></div>
      <div class="absolute bottom-1/4 right-1/3 w-[600px] h-[400px] bg-[var(--color-purple)]/[0.025] rounded-full blur-[160px]"></div>
    </div>

    <!-- Subtle grid -->
    <div class="absolute inset-0 pointer-events-none grid-bg opacity-40"></div>

    <!-- Radial fade at edges -->
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 70% 60% at 50% 45%, transparent 0%, #06060e 100%);"></div>

    <!-- Content -->
    <div class="relative z-10 flex flex-col items-center gap-8 max-w-3xl">

      <!-- Logo -->
      <div class="logo-wrapper">
        <div class="logo-glow"></div>
        <div class="logo-ring logo-ring--outer"></div>
        <div class="logo-ring logo-ring--inner"></div>
        <span class="particle p1"></span>
        <span class="particle p2"></span>
        <span class="particle p3"></span>
        <span class="particle p4"></span>
        <span class="particle p5"></span>
        <span class="particle p6"></span>
        <img
          src="/logofinal-transparent.png"
          alt="Aether8 AI Consulting - AI consultants in London, Ontario"
          class="hero-logo-img select-none"
        />
      </div>

      <!-- Tagline -->
      <p class="tagline text-white/60 font-light tracking-[0.3em] uppercase text-[clamp(0.7rem,1.8vw,0.9rem)]">
        Intelligent Systems. <span class="text-[var(--color-accent)]">Infinite Possibilities.</span>
      </p>

      <!-- Hero headline -->
      <h1 class="hero-headline text-[clamp(1.8rem,4.5vw,3.2rem)] font-bold leading-[1.15] tracking-tight text-white">
        We build <span class="gradient-text">agentic AI</span> that<br class="hidden sm:block" />
        runs your operations - reliably.
      </h1>

      <!-- Description -->
      <p class="description text-slate-400 max-w-xl text-center leading-relaxed text-[clamp(0.9rem,1.4vw,1.05rem)]">
        Forward-deployed AI consulting for small and medium businesses in Ontario, Canada. We embed with your team, build tailored AI solutions, and keep them running with SRE-grade observability.
      </p>

      <!-- CTAs -->
      <div class="cta-group flex flex-col sm:flex-row gap-4 items-center mt-2">
        <a
          href="mailto:hello@aether8.ai"
          class="cta-primary group relative inline-flex items-center gap-2.5 bg-white text-[#06060e] font-semibold px-8 py-3.5 rounded-full text-sm tracking-wide overflow-hidden cursor-pointer transition-all duration-300 hover:shadow-[0_0_40px_rgba(0,212,255,0.35)]"
        >
          <span class="relative z-10">Start a Project</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="relative z-10 group-hover:translate-x-1 transition-transform duration-200"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="#services" class="text-slate-500 hover:text-slate-300 transition-colors text-xs tracking-[0.2em] uppercase cursor-pointer">
          Explore Services ↓
        </a>
      </div>

      <!-- Status badge -->
      <div class="badge flex items-center gap-2.5 text-[11px] text-slate-600 tracking-[0.15em] uppercase mt-2">
        <span class="glow-dot"></span>
        Accepting New Clients · London, Ontario, Canada
      </div>

    </div>

    <!-- Scroll line -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 opacity-0 animate-fade-up delay-14">
      <span class="text-[10px] uppercase tracking-[0.3em] text-slate-700">Scroll</span>
      <div class="w-px h-10 bg-gradient-to-b from-slate-600 to-transparent animate-pulse"></div>
    </div>
  </section>

  <!-- ── Divider ── -->
  <div class="accent-line max-w-6xl mx-auto"></div>

  <!-- ── Services ───────────────────────────────────────────────────────────── -->
  <section id="services" class="py-32 px-6 relative">
    <div class="max-w-6xl mx-auto">

      <div class="text-center mb-20 reveal">
        <p class="text-[var(--color-accent)]/70 text-[11px] tracking-[0.35em] uppercase mb-4 font-medium">How We Work</p>
        <h2 class="text-3xl md:text-[2.75rem] font-bold tracking-tight leading-tight">Your Forward-Deployed<br class="hidden sm:block" /> AI Partner</h2>
        <p class="text-slate-400 mt-5 max-w-2xl mx-auto text-base leading-relaxed">
          We don't sell off-the-shelf tools. As London, Ontario's forward-deployed AI consultants, we embed with your team, learn your operations, and build AI that actually fits - then make sure it stays reliable.
        </p>
      </div>

      <!-- Service cards - Bento-style grid -->
      <div class="grid md:grid-cols-3 gap-4">

        <!-- Tailored AI Solutions -->
        <div class="glass-card group p-8 rounded-2xl cursor-default reveal">
          <div class="w-11 h-11 rounded-xl bg-[var(--color-accent)]/[0.08] flex items-center justify-center mb-6 group-hover:bg-[var(--color-accent)]/[0.15] transition-colors duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <h3 class="text-lg font-semibold mb-3 text-white">Tailored AI Solutions</h3>
          <p class="text-slate-400 text-[15px] leading-relaxed">No templates, no generic tools. We design and build agentic workflows shaped precisely around your business - automating the work that costs you the most time and people.</p>
          <div class="flex flex-wrap gap-2 mt-6">
            <span class="text-[10px] text-[var(--color-accent)]/50 tracking-[0.15em] uppercase border border-[var(--color-accent)]/10 px-3 py-1.5 rounded-full">Custom Build</span>
            <span class="text-[10px] text-[var(--color-accent)]/50 tracking-[0.15em] uppercase border border-[var(--color-accent)]/10 px-3 py-1.5 rounded-full">Workflow Design</span>
            <span class="text-[10px] text-[var(--color-accent)]/50 tracking-[0.15em] uppercase border border-[var(--color-accent)]/10 px-3 py-1.5 rounded-full">AI Integration</span>
          </div>
        </div>

        <!-- Forward-Deployed Engineering -->
        <div class="glass-card group p-8 rounded-2xl cursor-default reveal">
          <div class="w-11 h-11 rounded-xl bg-[var(--color-purple)]/[0.08] flex items-center justify-center mb-6 group-hover:bg-[var(--color-purple)]/[0.15] transition-colors duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-purple)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/></svg>
          </div>
          <h3 class="text-lg font-semibold mb-3 text-white">Forward-Deployed Engineering</h3>
          <p class="text-slate-400 text-[15px] leading-relaxed">We work alongside your team - not at arm's length. We learn your processes, surface where AI can make the biggest impact, and ship working solutions fast.</p>
          <div class="flex flex-wrap gap-2 mt-6">
            <span class="text-[10px] text-[var(--color-purple)]/50 tracking-[0.15em] uppercase border border-[var(--color-purple)]/10 px-3 py-1.5 rounded-full">Embedded Delivery</span>
            <span class="text-[10px] text-[var(--color-purple)]/50 tracking-[0.15em] uppercase border border-[var(--color-purple)]/10 px-3 py-1.5 rounded-full">Rapid Deployment</span>
          </div>
        </div>

        <!-- Security, Reliability & Observability -->
        <div class="glass-card group p-8 rounded-2xl cursor-default reveal">
          <div class="w-11 h-11 rounded-xl bg-emerald-500/[0.08] flex items-center justify-center mb-6 group-hover:bg-emerald-500/[0.15] transition-colors duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#34d399" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="text-lg font-semibold mb-3 text-white">Security, Reliability & Observability</h3>
          <p class="text-slate-400 text-[15px] leading-relaxed">Every system we build has guardrails baked in. Full audit trails, self-healing agents, zero hallucinations in production.</p>
          <div class="flex flex-wrap gap-2 mt-6">
            <span class="text-[10px] text-emerald-500/50 tracking-[0.15em] uppercase border border-emerald-500/10 px-3 py-1.5 rounded-full">Audit Trails</span>
            <span class="text-[10px] text-emerald-500/50 tracking-[0.15em] uppercase border border-emerald-500/10 px-3 py-1.5 rounded-full">Self-Healing</span>
            <span class="text-[10px] text-emerald-500/50 tracking-[0.15em] uppercase border border-emerald-500/10 px-3 py-1.5 rounded-full">SRE-Grade</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── About ──────────────────────────────────────────────────────────────── -->
  <section id="about" class="py-32 px-6 relative">
    <div class="accent-line max-w-6xl mx-auto mb-32"></div>
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-20 items-start">

      <div class="reveal">
        <p class="text-[var(--color-accent)]/70 text-[11px] tracking-[0.35em] uppercase mb-5 font-medium">Our Approach</p>
        <h2 class="text-3xl md:text-[2.75rem] font-bold tracking-tight leading-tight mb-7">
          Built for SMBs.<br/>Built to Last.
        </h2>
        <p class="text-slate-400 leading-relaxed mb-4 text-[15px]">
          AI adoption is hard for small and medium businesses - most tools are built for enterprises or require teams you don't have. Based in London, Ontario, we bridge that gap by acting as your <span class="text-white font-medium">on-demand Agentic AI consulting team</span>, handling the complexity so you don't have to.
        </p>
        <p class="text-slate-400 leading-relaxed text-[15px]">
          Whether you're a services firm, a logistics operation, a retail business, or anything in between - if repetitive work is slowing you down, we can automate it reliably.
        </p>

        <!-- Stats -->
        <div class="flex gap-12 mt-12 pt-8 border-t border-white/[0.06]">
          <div>
            <div class="text-3xl font-extrabold text-[var(--color-accent)]">0</div>
            <div class="text-[10px] text-slate-600 mt-1.5 tracking-[0.2em] uppercase">Hallucinations</div>
          </div>
          <div>
            <div class="text-3xl font-extrabold text-[var(--color-purple)]">∞</div>
            <div class="text-[10px] text-slate-600 mt-1.5 tracking-[0.2em] uppercase">Scalability</div>
          </div>
          <div>
            <div class="text-3xl font-extrabold text-white">100%</div>
            <div class="text-[10px] text-slate-600 mt-1.5 tracking-[0.2em] uppercase">Traceable</div>
          </div>
        </div>
      </div>

      <!-- Feature list -->
      <div class="space-y-3 reveal">
        <div class="glass-card p-5 rounded-xl flex gap-4">
          <div class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-2 shrink-0 shadow-[0_0_6px_var(--color-accent)]"></div>
          <div>
            <div class="text-sm font-medium text-white mb-1">Any Industry, Any Function</div>
            <div class="text-sm text-slate-500 leading-relaxed">Sales, operations, finance, HR, logistics - if humans are doing repetitive work, agents can do it better</div>
          </div>
        </div>
        <div class="glass-card p-5 rounded-xl flex gap-4">
          <div class="w-1.5 h-1.5 rounded-full bg-[var(--color-purple)] mt-2 shrink-0 shadow-[0_0_6px_var(--color-purple)]"></div>
          <div>
            <div class="text-sm font-medium text-white mb-1">No AI Team Required</div>
            <div class="text-sm text-slate-500 leading-relaxed">We handle architecture, deployment, and maintenance. You get the outcomes without building an internal AI practice</div>
          </div>
        </div>
        <div class="glass-card p-5 rounded-xl flex gap-4">
          <div class="w-1.5 h-1.5 rounded-full bg-emerald-400 mt-2 shrink-0 shadow-[0_0_6px_#34d399]"></div>
          <div>
            <div class="text-sm font-medium text-white mb-1">Self-Healing, Always-On</div>
            <div class="text-sm text-slate-500 leading-relaxed">Agents surface ambiguity for human review rather than guessing. Systems stay reliable even when the unexpected happens</div>
          </div>
        </div>
        <div class="glass-card p-5 rounded-xl flex gap-4">
          <div class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-2 shrink-0 shadow-[0_0_6px_var(--color-accent)]"></div>
          <div>
            <div class="text-sm font-medium text-white mb-1">Transparent by Design</div>
            <div class="text-sm text-slate-500 leading-relaxed">Every decision logged and traceable. You always know what your AI is doing, why it did it, and how to course-correct</div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ── Products ──────────────────────────────────────────────────────────────── -->
  <section id="products" class="py-32 px-6 relative">
    <div class="accent-line max-w-6xl mx-auto mb-32"></div>
    <div class="max-w-6xl mx-auto">

      <div class="text-center mb-16 reveal">
        <p class="text-[var(--color-accent)]/70 text-[11px] tracking-[0.35em] uppercase mb-4 font-medium">Our Products</p>
        <h2 class="text-3xl md:text-[2.75rem] font-bold tracking-tight">Find, win, and keep the right customers.</h2>
        <p class="text-slate-400 mt-4 max-w-xl mx-auto leading-relaxed">Three focused tools. One customer lifecycle. Every deployment tailored to your business.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Pursuit -->
        <div class="glass-card rounded-2xl p-8 flex flex-col gap-6 relative overflow-hidden reveal group">
          <div class="absolute top-0 left-0 w-[300px] h-[150px] bg-[var(--color-accent)]/[0.04] rounded-full blur-[80px] pointer-events-none"></div>
          <div class="relative z-10">
            <div class="text-3xl font-extrabold tracking-[0.05em] gradient-text mb-3">PURSUIT</div>
            <div class="inline-flex items-center gap-2 text-[10px] text-emerald-400/80 tracking-[0.2em] uppercase border border-emerald-400/20 bg-emerald-400/[0.05] px-3 py-1.5 rounded-full mb-4">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
              Live
            </div>
            <p class="text-white/70 text-[15px] leading-relaxed mb-5">The AI research agent your SDRs wish they had. Less research, more selling.</p>
            <ul class="flex flex-col gap-2 mb-6">
              <li class="flex items-start gap-2 text-slate-400 text-[13px]"><span class="w-1 h-1 rounded-full bg-[var(--color-accent)] mt-1.5 shrink-0 inline-block"></span>AI prospect research &amp; scoring</li>
              <li class="flex items-start gap-2 text-slate-400 text-[13px]"><span class="w-1 h-1 rounded-full bg-[var(--color-accent)] mt-1.5 shrink-0 inline-block"></span>Personalised outreach drafts</li>
              <li class="flex items-start gap-2 text-slate-400 text-[13px]"><span class="w-1 h-1 rounded-full bg-[var(--color-accent)] mt-1.5 shrink-0 inline-block"></span>CRM-ready export</li>
            </ul>
          </div>
          <div class="relative z-10 mt-auto flex flex-col gap-3">
            <a href="https://pursuit.aether8.ai" class="cta-primary group/btn inline-flex items-center justify-center gap-2 bg-white text-[#06060e] px-5 py-2.5 rounded-full text-[13px] font-semibold tracking-wide hover:bg-[var(--color-accent)] transition-all duration-300">
              Talk to Us
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover/btn:translate-x-1 transition-transform duration-200"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- Showwalker -->
        <div class="glass-card rounded-2xl p-8 flex flex-col gap-6 relative overflow-hidden reveal group">
          <div class="absolute top-0 right-0 w-[300px] h-[150px] bg-[var(--color-purple)]/[0.04] rounded-full blur-[80px] pointer-events-none"></div>
          <div class="relative z-10">
            <div class="text-3xl font-extrabold tracking-[0.05em] mb-3" style="background: linear-gradient(135deg, #a855f7, #00d4ff); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">SHOWWALKER</div>
            <div class="inline-flex items-center gap-2 text-[10px] text-amber-400/70 tracking-[0.2em] uppercase border border-amber-400/15 bg-amber-400/[0.04] px-3 py-1.5 rounded-full mb-4">
              <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span>
              Early Access
            </div>
            <p class="text-white/70 text-[15px] leading-relaxed mb-5">Turn any tradeshow exhibitor list into a scored, qualified lead pipeline. Minutes, not days.</p>
            <ul class="flex flex-col gap-2 mb-6">
              <li class="flex items-start gap-2 text-slate-400 text-[13px]"><span class="w-1 h-1 rounded-full bg-[var(--color-purple)] mt-1.5 shrink-0 inline-block"></span>Research &amp; score every exhibitor</li>
              <li class="flex items-start gap-2 text-slate-400 text-[13px]"><span class="w-1 h-1 rounded-full bg-[var(--color-purple)] mt-1.5 shrink-0 inline-block"></span>Custom keyword scoring model</li>
              <li class="flex items-start gap-2 text-slate-400 text-[13px]"><span class="w-1 h-1 rounded-full bg-[var(--color-purple)] mt-1.5 shrink-0 inline-block"></span>One-click CRM push</li>
            </ul>
          </div>
          <div class="relative z-10 mt-auto flex flex-col gap-3">
            <a href="https://showwalker.aether8.ai" class="group/btn inline-flex items-center justify-center gap-2 border border-[var(--color-purple)]/30 text-white/80 px-5 py-2.5 rounded-full text-[13px] font-medium tracking-wide hover:border-[var(--color-purple)]/60 hover:text-[var(--color-purple)] hover:bg-[var(--color-purple)]/5 transition-all duration-300">
              Request Access
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover/btn:translate-x-1 transition-transform duration-200"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- Scrnr -->
        <div class="glass-card rounded-2xl p-8 flex flex-col gap-6 relative overflow-hidden reveal group">
          <div class="absolute bottom-0 left-0 w-[300px] h-[150px] bg-emerald-500/[0.04] rounded-full blur-[80px] pointer-events-none"></div>
          <div class="relative z-10">
            <div class="text-3xl font-extrabold tracking-[0.05em] mb-3" style="background: linear-gradient(135deg, #34d399, #00d4ff); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">SCRNR</div>
            <div class="inline-flex items-center gap-2 text-[10px] text-amber-400/70 tracking-[0.2em] uppercase border border-amber-400/15 bg-amber-400/[0.04] px-3 py-1.5 rounded-full mb-4">
              <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span>
              Early Access
            </div>
            <p class="text-white/70 text-[15px] leading-relaxed mb-5">Stop paying people to call contacts who moved two years ago. AI-powered contact hygiene and pre-screening.</p>
            <ul class="flex flex-col gap-2 mb-6">
              <li class="flex items-start gap-2 text-slate-400 text-[13px]"><span class="w-1 h-1 rounded-full bg-emerald-400 mt-1.5 shrink-0 inline-block"></span>AI contact verification</li>
